backend/cache/*
# Exception: ship the small OSM JSON cache so the HF Space Dockerfile can pre-bake
# the Köyceğiz demo (Dockerfile does `COPY backend/cache/osm/`).
!backend/cache/osm/
backend/cache/osm/**.tif
backend/__pycache__/
backend/.venv/
**/__pycache__/
**/.DS_Store
frontend/node_modules/
frontend/dist/
.run-logs/
.claude/
~$*


# Local Netlify folder
.netlify
